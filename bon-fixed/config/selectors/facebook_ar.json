{
  "version": "2026-03",
  "description": "محددات فيسبوك للواجهة العربية",
  "selectors": {
    "publish_button": [
      {"type": "role", "value": "button", "name": "نشر"},
      {"type": "text", "value": "نشر"},
      {"type": "aria", "value": "نشر"},
      {"type": "xpath", "value": "//div[@role='button' and contains(text(), 'نشر')]"}
    ],
    "display_input": [
      {"type": "aria", "value": "اكتب شيئاً"},
      {"type": "role", "value": "button", "name": "اكتب"},
      {"type": "text", "value": "اكتب شيئاً"},
      {"type": "xpath", "value": "//div[@role='button' and contains(@aria-label, 'اكتب')]"}
    ],
    "input": [
      {"type": "role", "value": "textbox"},
      {"type": "aria", "value": "اكتب"},
      {"type": "css", "value": "div[role='textbox'][contenteditable='true']"},
      {"type": "xpath", "value": "//div[@role='textbox' and @contenteditable='true']"}
    ],
    "show_image_input": [
      {"type": "aria", "value": "صورة/فيديو"},
      {"type": "text", "value": "صورة"},
      {"type": "css", "value": "[aria-label*='صورة']"},
      {"type": "xpath", "value": "//div[contains(@aria-label, 'صورة')]"}
    ],
    "add_image": [
      {"type": "css", "value": "input[type='file'][accept*='image']"},
      {"type": "xpath", "value": "//input[@type='file' and contains(@accept, 'image')]"}
    ],
    "submit": [
      {"type": "aria", "value": "نشر"},
      {"type": "role", "value": "button", "name": "نشر"},
      {"type": "text", "value": "نشر"},
      {"type": "xpath", "value": "//div[@role='button' and contains(@aria-label, 'نشر')]"}
    ]
  }
}
