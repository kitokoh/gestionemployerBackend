{
  "version": "2026-03",
  "description": "Sélecteurs Facebook pour interface française",
  "selectors": {
    "publish_button": [
      {"type": "role", "value": "button", "name": "Publier"},
      {"type": "text", "value": "Publier"},
      {"type": "aria", "value": "Publier"},
      {"type": "xpath", "value": "//div[@role='button' and contains(text(), 'Publier')]"}
    ],
    "display_input": [
      {"type": "aria", "value": "Écrire quelque chose"},
      {"type": "role", "value": "button", "name": "Écrire"},
      {"type": "text", "value": "Écrire quelque chose"},
      {"type": "xpath", "value": "//div[@role='button' and contains(@aria-label, 'Écrire')]"}
    ],
    "input": [
      {"type": "role", "value": "textbox"},
      {"type": "aria", "value": "Écrire"},
      {"type": "css", "value": "div[role='textbox'][contenteditable='true']"},
      {"type": "xpath", "value": "//div[@role='textbox' and @contenteditable='true']"}
    ],
    "show_image_input": [
      {"type": "aria", "value": "Photo/vidéo"},
      {"type": "text", "value": "Photo"},
      {"type": "css", "value": "[aria-label*='Photo']"},
      {"type": "xpath", "value": "//div[contains(@aria-label, 'Photo')]"}
    ],
    "add_image": [
      {"type": "css", "value": "input[type='file'][accept*='image']"},
      {"type": "xpath", "value": "//input[@type='file' and contains(@accept, 'image')]"}
    ],
    "submit": [
      {"type": "aria", "value": "Publier"},
      {"type": "role", "value": "button", "name": "Publier"},
      {"type": "text", "value": "Publier"},
      {"type": "xpath", "value": "//div[@role='button' and contains(@aria-label, 'Publier')]"}
    ]
  }
}
