APP_NAME="Leopardo RH"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.leopardo-rh.com
APP_TIMEZONE=UTC

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Base de données PostgreSQL 16 (Multi-tenant)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=leopardo_db
DB_USERNAME=leopardo_user
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE_EN_PROD

# Redis (Cache + Queues)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache
CACHE_DRIVER=redis
CACHE_PREFIX=leopardo_

# Sessions
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# Queues (Horizon)
QUEUE_CONNECTION=redis
HORIZON_ENVIRONMENTS=production

# Mail SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=VOTRE_USERNAME_SMTP
MAIL_PASSWORD=VOTRE_PASSWORD_SMTP
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@leopardo-rh.com
MAIL_FROM_NAME="Leopardo RH"

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
FIREBASE_PROJECT_ID=leopardo-rh-xxxxx

# Sanctum (Auth Tokens)
SANCTUM_STATEFUL_DOMAINS=app.leopardo-rh.com,localhost

# CORS
CORS_ALLOWED_ORIGINS=https://app.leopardo-rh.com,https://leopardo-rh.com

# PDF (DomPDF)
DOMPDF_PAPER_SIZE=A4
DOMPDF_ENABLE_REMOTE=false

# Stockage (fichiers bulletins, photos, logos)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_URL=

# Super Admin (premier compte créé manuellement)
SUPER_ADMIN_EMAIL=admin@leopardo-rh.com
SUPER_ADMIN_PASSWORD=CHANGER_EN_PROD

# Telescope (désactiver en prod si pas nécessaire)
TELESCOPE_ENABLED=false

# Rate Limiting
RATE_LIMIT_API=60

# Multi-tenant
TENANCY_DEFAULT_TYPE=shared
