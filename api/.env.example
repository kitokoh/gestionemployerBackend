APP_NAME="Leopardo RH"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.leopardo-rh.com
APP_TIMEZONE=UTC
# Version semver exposee par /api/v1/health (doit suivre CHANGELOG.md).
# Peut etre injectee au deploy depuis un CI var (ex : commit court).
APP_VERSION=4.1.70

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=leopardo_db
DB_USERNAME=leopardo_user
DB_PASSWORD=CHANGER_CE_MOT_DE_PASSE_EN_PROD
DB_SEARCH_PATH=shared_tenants,public

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=VOTRE_USERNAME_SMTP
MAIL_PASSWORD=VOTRE_PASSWORD_SMTP
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@leopardo-rh.com
MAIL_FROM_NAME="Leopardo RH"

SANCTUM_STATEFUL_DOMAINS=app.leopardo-rh.com,localhost
SANCTUM_TOKEN_EXPIRATION=10080
CORS_ALLOWED_ORIGINS=https://app.leopardo-rh.com,https://leopardo-rh.com

DOMPDF_PAPER_SIZE=A4
DOMPDF_ENABLE_REMOTE=false

FILESYSTEM_DISK=local

BACKUP_PATH=/var/backups/leopardo
BACKUP_KEEP_LAST=10

TELESCOPE_ENABLED=false
RATE_LIMIT_API=60
TENANCY_DEFAULT_TYPE=shared

# Super Admin (cree par SuperAdminSeeder a la 1ere execution de `php artisan leopardo:migrate --seed`)
# - Se connecte sur /platform/login (web) ou POST /api/v1/platform/auth/login (API)
# - Si SUPER_ADMIN_PASSWORD est vide, le seeder genere un mot de passe aleatoire affiche dans les logs
# - Pour changer le mot de passe a tout moment :
#     php artisan super-admin:reset-password admin@leopardo-rh.com NouveauMotDePasse
SUPER_ADMIN_EMAIL=admin@leopardo-rh.com
SUPER_ADMIN_PASSWORD=
FORCE_SUPER_ADMIN_PASSWORD_RESET=false
